{
  "name": "@taskflow-ai/core",
  "version": "2.2.0",
  "description": "TaskFlow AI 核心库 - 任务管理、工作流引擎、插件系统",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tasks": {
      "import": "./dist/tasks/index.js",
      "types": "./dist/tasks/index.d.ts"
    },
    "./workflow": {
      "import": "./dist/workflow/index.js",
      "types": "./dist/workflow/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin/index.js",
      "types": "./dist/plugin/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "taskflow",
    "workflow",
    "tasks",
    "plugin",
    "automation"
  ],
  "author": "Agions",
  "license": "MIT",
  "dependencies": {
    "xstate": "^5.28.0",
    "@xstate/fsm": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
